generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  SPIELER
  DUNGEON_MASTER
  ADMIN
}

enum JournalTyp {
  TAGEBUCH
  GESCHICHTE
}

enum TagTyp {
  PERSON
  ORGANISATION
  CHARAKTER
  SPIELER
  LOCATION
}

// ─── Auth ────────────────────────────────────────────────

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  passwordHash       String
  role               Role               @default(SPIELER)
  emailVerified      Boolean            @default(true)  // true = no verification needed (existing/setup users)
  emailVerifyToken   String?            @unique
  resetToken         String?            @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime           @default(now())
  charaktere         Charakter[]
  eintraege          JournalEntry[]
  kampagnen          KampagneMitglied[]
}

model Invite {
  id         String    @id @default(cuid())
  token      String    @unique @default(cuid())
  usedById   String?
  role       Role      @default(SPIELER)
  kampagneId String?
  kampagne   Kampagne? @relation(fields: [kampagneId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
}

// ─── Kampagnen ───────────────────────────────────────────

model Kampagne {
  id             String             @id @default(cuid())
  name           String
  beschreibung   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  mitglieder     KampagneMitglied[]
  npcs           NPC[]
  organisationen Organisation[]
  charaktere     Charakter[]
  locations      Location[]
  eintraege      JournalEntry[]
  invites        Invite[]
}

model KampagneMitglied {
  id         String   @id @default(cuid())
  kampagneId String
  userId     String
  isDM       Boolean  @default(false)
  isOwner    Boolean  @default(false)
  createdAt  DateTime @default(now())

  kampagne Kampagne @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([kampagneId, userId])
}

// ─── DM content ──────────────────────────────────────────

model NPC {
  id               String            @id @default(cuid())
  kampagneId       String?
  kampagne         Kampagne?         @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  name             String
  image            String?
  status           String            @default("Unbekannt")
  beziehung        String            @default("Unbekannt")
  geschlecht       String?
  region           String?
  alter            String?
  rasse            String?
  herkunft         String?
  aktuellePosition String?
  gottheit         String?
  notizen          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organisationen   NPCOrganisation[]
  locations        Location[]
}

model Organisation {
  id                  String                  @id @default(cuid())
  kampagneId          String?
  kampagne            Kampagne?               @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  name                String
  beschreibung        String?
  typ                 String?
  region              String?
  alignment           String?
  beziehungZurGruppe  String?
  gottheit            String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  mitglieder          NPCOrganisation[]
  charakterMitglieder CharakterOrganisation[]
  locations           Location[]
}

model NPCOrganisation {
  id             String       @id @default(cuid())
  npc            NPC          @relation(fields: [npcId], references: [id], onDelete: Cascade)
  npcId          String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  organisationId String
  rolle          String?
  createdAt      DateTime     @default(now())

  @@unique([npcId, organisationId])
}

// ─── Player characters ───────────────────────────────────

model Charakter {
  id               String                  @id @default(cuid())
  kampagneId       String?
  kampagne         Kampagne?               @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  image            String?
  status           String                  @default("Lebendig")
  beziehung        String                  @default("Neutral")
  geschlecht       String?
  region           String?
  alter            String?
  rasse            String?
  herkunft         String?
  aktuellePosition String?
  gottheit         String?
  notizen          String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  organisationen   CharakterOrganisation[]
  locations        Location[]
}

model CharakterOrganisation {
  id             String       @id @default(cuid())
  charakter      Charakter    @relation(fields: [charakterId], references: [id], onDelete: Cascade)
  charakterId    String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  organisationId String
  rolle          String?
  createdAt      DateTime     @default(now())

  @@unique([charakterId, organisationId])
}

// ─── Locations ───────────────────────────────────────────

model Location {
  id            String         @id @default(cuid())
  kampagneId    String
  kampagne      Kampagne       @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  name          String
  art           String?
  land          String?
  region        String?
  population    Int?
  klima         String?
  floraFauna    String?
  wissenswertes String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  npcs          NPC[]
  organisationen Organisation[]
  charaktere    Charakter[]
}

// ─── Journal ─────────────────────────────────────────────

model JournalEntry {
  id         String       @id @default(cuid())
  kampagneId String?
  kampagne   Kampagne?    @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  typ        JournalTyp
  titel      String?
  inhalt     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  tags       JournalTag[]
}

model JournalTag {
  id         String       @id @default(cuid())
  entry      JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId    String
  tagTyp     TagTyp
  referenzId String
}

// ─── Site Settings (singleton) ───────────────────────────

model SiteSettings {
  id                 String   @id @default("singleton")
  copyrightText      String   @default("© Lorehub. Alle Rechte vorbehalten.")
  kontaktEmail       String   @default("")
  impressumContent   String   @default("")
  datenschutzContent String   @default("")
  updatedAt          DateTime @updatedAt
}
