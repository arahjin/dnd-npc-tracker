generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  SPIELER
  DUNGEON_MASTER
  ADMIN
}

enum JournalTyp {
  TAGEBUCH
  GESCHICHTE
}

enum TagTyp {
  PERSON
  ORGANISATION
  CHARAKTER
  SPIELER
  LOCATION
}

// ─── Auth ────────────────────────────────────────────────

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  passwordHash       String
  role               Role               @default(SPIELER)
  emailVerified      Boolean            @default(true)  // true = no verification needed (existing/setup users)
  emailVerifyToken   String?            @unique
  resetToken         String?            @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime           @default(now())
  charaktere         Charakter[]
  eintraege          JournalEntry[]
  kampagnen          KampagneMitglied[]
  erstellteNPCs           NPC[]          @relation("erstellteNPCs")
  erstellteOrganisationen Organisation[] @relation("erstellteOrganisationen")
  erstellteLocations      Location[]     @relation("erstellteLocations")
  bildGenerierungen       BildGenerierung[]
  rateLimitEvents         RateLimitEvent[]
  erstellteQuests         Quest[]        @relation("erstellteQuests")
}

// Tracks DALL-E image generation per user for rate limiting
model BildGenerierung {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Generic rate-limit ledger. One row per state-changing API call.
// Cleanup is opportunistic (purgeOldRateLimitEvents() in lib/rateLimit.ts).
model RateLimitEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
  @@index([createdAt])
}

model Invite {
  id         String    @id @default(cuid())
  token      String    @unique @default(cuid())
  usedById   String?
  role       Role      @default(SPIELER)
  kampagneId String?
  kampagne   Kampagne? @relation(fields: [kampagneId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
}

// ─── Kampagnen ───────────────────────────────────────────

model Kampagne {
  id             String             @id @default(cuid())
  name           String
  beschreibung   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  mitglieder     KampagneMitglied[]
  npcs           NPC[]
  organisationen Organisation[]
  charaktere     Charakter[]
  locations      Location[]
  eintraege      JournalEntry[]
  invites        Invite[]
  quests         Quest[]
}

model KampagneMitglied {
  id         String   @id @default(cuid())
  kampagneId String
  userId     String
  isDM       Boolean  @default(false)
  isOwner    Boolean  @default(false)
  createdAt  DateTime @default(now())

  kampagne Kampagne @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([kampagneId, userId])
}

// ─── DM content ──────────────────────────────────────────

model NPC {
  id               String            @id @default(cuid())
  kampagneId       String?
  kampagne         Kampagne?         @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  name             String
  image            String?
  status           String            @default("Unbekannt")
  beziehung        String            @default("Unbekannt")
  geschlecht       String?
  region           String?
  alter            String?
  rasse            String?
  herkunft         String?
  aktuellePosition String?
  gottheit         String?
  notizen          String?
  sichtbarkeit     String            @default("public")
  privateNotizen   String?
  erstellerId      String?
  ersteller        User?             @relation("erstellteNPCs", fields: [erstellerId], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organisationen   NPCOrganisation[]
  locations        Location[]
  quests           QuestNPC[]

  @@index([kampagneId])
  @@index([kampagneId, name])
}

model Organisation {
  id                  String                  @id @default(cuid())
  kampagneId          String?
  kampagne            Kampagne?               @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  name                String
  beschreibung        String?
  typ                 String?
  region              String?
  alignment           String?
  beziehungZurGruppe  String?
  gottheit            String?
  sichtbarkeit        String                  @default("public")
  privateNotizen      String?
  erstellerId         String?
  ersteller           User?                   @relation("erstellteOrganisationen", fields: [erstellerId], references: [id], onDelete: SetNull)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  mitglieder          NPCOrganisation[]
  charakterMitglieder CharakterOrganisation[]
  locations           Location[]
  quests              QuestOrganisation[]

  @@index([kampagneId])
}

model NPCOrganisation {
  id             String       @id @default(cuid())
  npc            NPC          @relation(fields: [npcId], references: [id], onDelete: Cascade)
  npcId          String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  organisationId String
  rolle          String?

  @@unique([npcId, organisationId])
}

// ─── Player characters ───────────────────────────────────

model Charakter {
  id               String                  @id @default(cuid())
  kampagneId       String?
  kampagne         Kampagne?               @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  image            String?
  status           String                  @default("Lebendig")
  beziehung        String                  @default("Neutral")
  geschlecht       String?
  region           String?
  alter            String?
  rasse            String?
  herkunft         String?
  aktuellePosition String?
  gottheit         String?
  notizen          String?
  sichtbarkeit     String                  @default("public")
  privateNotizen   String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  organisationen   CharakterOrganisation[]
  locations        Location[]
  quests           QuestCharakter[]

  @@index([kampagneId])
  @@index([userId])
}

model CharakterOrganisation {
  id             String       @id @default(cuid())
  charakter      Charakter    @relation(fields: [charakterId], references: [id], onDelete: Cascade)
  charakterId    String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  organisationId String
  rolle          String?

  @@unique([charakterId, organisationId])
}

// ─── Locations ───────────────────────────────────────────

model Location {
  id            String         @id @default(cuid())
  kampagneId    String
  kampagne      Kampagne       @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  name          String
  art           String?
  land          String?
  region        String?
  population    Int?
  klima         String?
  floraFauna    String?
  wissenswertes  String?
  sichtbarkeit   String         @default("public")
  privateNotizen String?
  erstellerId    String?
  ersteller      User?          @relation("erstellteLocations", fields: [erstellerId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  npcs           NPC[]
  organisationen Organisation[]
  charaktere     Charakter[]
  quests         QuestLocation[]

  @@index([kampagneId])
}

// ─── Journal ─────────────────────────────────────────────

model JournalEntry {
  id         String       @id @default(cuid())
  kampagneId String?
  kampagne   Kampagne?    @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  typ        JournalTyp
  titel      String?
  inhalt     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  tags       JournalTag[]
  quests     QuestJournalEntry[]

  @@index([kampagneId, createdAt])
  @@index([userId])
  @@index([typ])
}

model JournalTag {
  id         String       @id @default(cuid())
  entry      JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId    String
  tagTyp     TagTyp
  referenzId String

  @@index([entryId])
  @@index([tagTyp, referenzId])
}

// ─── Quests ──────────────────────────────────────────────

model Quest {
  id           String    @id @default(cuid())
  kampagneId   String
  kampagne     Kampagne  @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  title        String
  status       String    @default("Aktiv")
  typ          String    @default("Nebenquest")
  prioritaet   String?
  summary      String?
  description  String?
  reward       String?
  gmNotes      String?
  deadline     String?
  sichtbarkeit String    @default("public")
  erstellerId  String?
  ersteller    User?     @relation("erstellteQuests", fields: [erstellerId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  objectives     QuestObjective[]
  npcs           QuestNPC[]
  locations      QuestLocation[]
  organisationen QuestOrganisation[]
  charaktere     QuestCharakter[]
  journalEntries QuestJournalEntry[]
  vorlaeuferVon  QuestRelation[]     @relation("nachfolgerQuest")
  nachfolgerVon  QuestRelation[]     @relation("vorlaeuferQuest")

  @@index([kampagneId])
  @@index([kampagneId, status])
}

model QuestObjective {
  id      String  @id @default(cuid())
  questId String
  quest   Quest   @relation(fields: [questId], references: [id], onDelete: Cascade)
  label   String
  done    Boolean @default(false)
  order   Int     @default(0)
}

model QuestNPC {
  id      String @id @default(cuid())
  questId String
  quest   Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  npcId   String
  npc     NPC    @relation(fields: [npcId], references: [id], onDelete: Cascade)
  rolle   String?
  @@unique([questId, npcId])
}

model QuestLocation {
  id         String   @id @default(cuid())
  questId    String
  quest      Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  rolle      String?
  @@unique([questId, locationId])
}

model QuestOrganisation {
  id             String       @id @default(cuid())
  questId        String
  quest          Quest        @relation(fields: [questId], references: [id], onDelete: Cascade)
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  rolle          String?
  @@unique([questId, organisationId])
}

model QuestCharakter {
  id          String    @id @default(cuid())
  questId     String
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  charakterId String
  charakter   Charakter @relation(fields: [charakterId], references: [id], onDelete: Cascade)
  rolle       String?
  @@unique([questId, charakterId])
}

model QuestJournalEntry {
  id      String       @id @default(cuid())
  questId String
  quest   Quest        @relation(fields: [questId], references: [id], onDelete: Cascade)
  entryId String
  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  typ     String?
  @@unique([questId, entryId])
}

model QuestRelation {
  id                String @id @default(cuid())
  vorlaeuferQuestId String
  vorlaeuferQuest   Quest  @relation("vorlaeuferQuest", fields: [vorlaeuferQuestId], references: [id], onDelete: Cascade)
  nachfolgerQuestId String
  nachfolgerQuest   Quest  @relation("nachfolgerQuest", fields: [nachfolgerQuestId], references: [id], onDelete: Cascade)
  relation          String?
  @@unique([vorlaeuferQuestId, nachfolgerQuestId])
}

// ─── Site Settings (singleton) ───────────────────────────

model SiteSettings {
  id                 String   @id @default("singleton")
  copyrightText      String   @default("© Lorehub. Alle Rechte vorbehalten.")
  kontaktEmail       String   @default("")
  discordUrl         String   @default("")
  impressumContent   String   @default("")
  datenschutzContent String   @default("")
  landingTitle       String   @default("Lorehub")
  landingSubtitle    String   @default("Dein digitales Kampagnen-Archiv")
  landingBody        String   @default("")
  updatedAt          DateTime @updatedAt
}
