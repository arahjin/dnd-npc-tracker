generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model NPC {
  id               String   @id @default(cuid())
  name             String
  image            String?
  status           String   @default("Unbekannt")
  beziehung        String   @default("Unbekannt")
  geschlecht       String?
  region           String?
  organisationen   String?
  alter            String?
  rasse            String?
  herkunft         String?
  aktuellePosition String?
  notizen          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
